            "widget_code": "\n<style>\n  .metric-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 1.5rem; }\n  .metric { background: var(--color-background-secondary); border-radius: var(--border-radius-md); padding: 0.875rem 1rem; }\n  .metric-label { font-size: 12px; color: var(--color-text-secondary); margin-bottom: 4px; }\n  .metric-value { font-size: 22px; font-weight: 500; }\n  .section-label { font-size: 12px; color: var(--color-text-secondary); font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; margin: 1.5rem 0 0.75rem; }\n  .sender-row { display: flex; align-items: center; gap: 10px; padding: 8px 0; border-bottom: 0.5px solid var(--color-border-tertiary); }\n  .sender-row:last-child { border-bottom: none; }\n  .bar-wrap { flex: 1; background: var(--color-background-secondary); border-radius: 3px; height: 8px; overflow: hidden; }\n  .bar { height: 100%; border-radius: 3px; transition: width 0.4s ease; }\n  .sender-name { font-size: 13px; min-width: 170px; max-width: 170px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\n  .sender-count { font-size: 13px; font-weight: 500; min-width: 24px; text-align: right; }\n  .cat-badge { font-size: 11px; padding: 2px 7px; border-radius: var(--border-radius-md); min-width: 64px; text-align: center; }\n  .cat-promo { background: #FAEEDA; color: #854F0B; }\n  .cat-news { background: #E6F1FB; color: #185FA5; }\n  .cat-sys { background: #F1EFE8; color: #5F5E5A; }\n  .cat-korea { background: #EAF3DE; color: #3B6D11; }\n  .tab-bar { display: flex; gap: 6px; margin-bottom: 1.25rem; flex-wrap: wrap; }\n  .tab { padding: 5px 13px; font-size: 13px; border: 0.5px solid var(--color-border-secondary); border-radius: var(--border-radius-md); background: transparent; color: var(--color-text-secondary); cursor: pointer; }\n  .tab.active { background: var(--color-background-secondary); color: var(--color-text-primary); border-color: var(--color-border-primary); font-weight: 500; }\n  .action-btn { font-size: 12px; padding: 3px 9px; border: 0.5px solid var(--color-border-secondary); border-radius: var(--border-radius-md); background: transparent; color: var(--color-text-secondary); cursor: pointer; margin-left: auto; }\n  .action-btn:hover { background: var(--color-background-secondary); }\n  .verdict { font-size: 12px; padding: 2px 8px; border-radius: var(--border-radius-md); }\n  .v-cut { background: #FCEBEB; color: #A32D2D; }\n  .v-keep { background: #EAF3DE; color: #3B6D11; }\n  .v-review { background: #FAEEDA; color: #854F0B; }\n  @media (prefers-color-scheme: dark) {\n    .cat-promo { background: #412402; color: #FAC775; }\n    .cat-news { background: #042C53; color: #B5D4F4; }\n    .cat-sys { background: #2C2C2A; color: #B4B2A9; }\n    .cat-korea { background: #173404; color: #C0DD97; }\n    .v-cut { background: #501313; color: #F7C1C1; }\n    .v-keep { background: #173404; color: #C0DD97; }\n    .v-review { background: #412402; color: #FAC775; }\n  }\n</style>\n\n<div style=\"padding: 1rem 0 0.5rem;\">\n\n<div class=\"metric-grid\">\n  <div class=\"metric\"><div class=\"metric-label\">Unread emails</div><div class=\"metric-value\">100+</div></div>\n  <div class=\"metric\"><div class=\"metric-label\">Unique senders</div><div class=\"metric-value\">28</div></div>\n  <div class=\"metric\"><div class=\"metric-label\">Loudest sender</div><div class=\"metric-value\" style=\"font-size:15px; padding-top:4px;\">CoolDeep AI</div></div>\n  <div class=\"metric\"><div class=\"metric-label\">Suggested cuts</div><div class=\"metric-value\" style=\"color:#A32D2D;\">11</div></div>\n</div>\n\n<div class=\"tab-bar\" id=\"tabs\">\n  <button class=\"tab active\" onclick=\"showTab('all',this)\">All senders</button>\n  <button class=\"tab\" onclick=\"showTab('cut',this)\">Unsubscribe</button>\n  <button class=\"tab\" onclick=\"showTab('review',this)\">Review</button>\n  <button class=\"tab\" onclick=\"showTab('keep',this)\">Keep</button>\n</div>\n\n<div id=\"sender-list\"></div>\n\n<div class=\"section-label\" style=\"margin-top:1.75rem;\">Volume by category</div>\n<div style=\"position:relative; width:100%; height:200px;\"><canvas id=\"catChart\"></canvas></div>\n\n<div style=\"font-size:12px; color:var(--color-text-secondary); margin-top:1.5rem; padding-top:0.75rem; border-top:0.5px solid var(--color-border-tertiary);\">\n  Based on 100 most recent unread subscription emails ¬Ј sampled Mar 24вАУ31, 2026\n</div>\n</div>\n\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js\"></script>\n<script>\nconst senders = [\n  { name: \"CoolDeep AI\", domain: \"cooldeepai@mail.beehiiv.com\", count: 12, cat: \"news\", catLabel: \"newsletter\", verdict: \"cut\", reason: \"High-frequency AI newsletter, very repetitive subjects\" },\n  { name: \"The Rundown AI\", domain: \"news@daily.therundown.ai\", count: 5, cat: \"news\", catLabel: \"newsletter\", verdict: \"keep\", reason: \"Daily AI news вАФ broadly relevant to AX work\" },\n  { name: \"Daily Dose of DS\", domain: \"avi@dailydoseofds.com\", count: 5, cat: \"news\", catLabel: \"newsletter\", verdict: \"keep\", reason: \"Technical DS/ML content with code вАФ useful\" },\n  { name: \"GitHub (notifications)\", domain: \"notifications@github.com\", count: 5, cat: \"sys\", catLabel: \"system\", verdict: \"review\", reason: \"Workflow failure emails вАФ fix the workflow or mute\" },\n  { name: \"Uber / Uber Eats\", domain: \"uber@uber.com\", count: 3, cat: \"promo\", catLabel: \"promo\", verdict: \"cut\", reason: \"Promotional & order nudge emails\" },\n  { name: \"McKinsey & Co.\", domain: \"publishing@email.mckinsey.com\", count: 3, cat: \"news\", catLabel: \"newsletter\", verdict: \"keep\", reason: \"Strategy / AI insights relevant to CHO work\" },\n  { name: \"Replit\", domain: \"contact@mail.replit.com\", count: 3, cat: \"promo\", catLabel: \"promo\", verdict: \"review\", reason: \"Mix of product news + promo; decide if you use it\" },\n  { name: \"The Rundown Robotics\", domain: \"hi@robotics.therundown.ai\", count: 2, cat: \"news\", catLabel: \"newsletter\", verdict: \"keep\", reason: \"Physical AI / robotics вАФ core to 2026 mission\" },\n  { name: \"FOX One\", domain: \"foxone@m.fox.com\", count: 2, cat: \"promo\", catLabel: \"promo\", verdict: \"cut\", reason: \"Sports/TV content вАФ likely not intentional sub\" },\n  { name: \"Coursera\", domain: \"Coursera@m.learn.coursera.org\", count: 2, cat: \"promo\", catLabel: \"promo\", verdict: \"cut\", reason: \"Generic course push emails\" },\n  { name: \"CodePen\", domain: \"support@codepen.io\", count: 2, cat: \"news\", catLabel: \"newsletter\", verdict: \"review\", reason: \"CSS/frontend вАФ useful only if actively building UI\" },\n  { name: \"Substack\", domain: \"no-reply@substack.com\", count: 2, cat: \"sys\", catLabel: \"system\", verdict: \"keep\", reason: \"Platform notifications for your own Substack\" },\n  { name: \"Ollama\", domain: \"hello@ollama.com\", count: 2, cat: \"news\", catLabel: \"newsletter\", verdict: \"keep\", reason: \"LLM tooling updates вАФ relevant to dev workflow\" },\n  { name: \"Gallup\", domain: \"gallup@e.gallup.com\", count: 2, cat: \"news\", catLabel: \"newsletter\", verdict: \"keep\", reason: \"Organizational research вАФ relevant to Pulse Check\" },\n  { name: \"GPT Workspace\", domain: \"contact@gpt.space\", count: 1, cat: \"promo\", catLabel: \"promo\", verdict: \"cut\", reason: \"Upsell email вАФ not useful\" },\n  { name: \"Dan at Vercel\", domain: \"ship@info.vercel.com\", count: 1, cat: \"news\", catLabel: \"newsletter\", verdict: \"review\", reason: \"Infra/agent building вАФ depends on Vercel usage\" },\n  { name: \"Atlassian\", domain: \"noreply@po.atlassian.net\", count: 2, cat: \"sys\", catLabel: \"system\", verdict: \"review\", reason: \"Inactive Jira/Confluence вАФ action needed\" },\n  { name: \"simple.ai (Dharmesh)\", domain: \"agentai@mail.beehiiv.com\", count: 1, cat: \"news\", catLabel: \"newsletter\", verdict: \"keep\", reason: \"AI agent strategy content\" },\n  { name: \"Catch Paper\", domain: \"catchpaper@mail.beehiiv.com\", count: 1, cat: \"news\", catLabel: \"newsletter\", verdict: \"keep\", reason: \"Research paper digests вАФ relevant for LV3+ dev\" },\n  { name: \"м°∞мЙђмЭШ лЙімК§л†ИнД∞\", domain: \"josh@maily.so\", count: 1, cat: \"korea\", catLabel: \"нХЬкµ≠мЦі\", verdict: \"keep\", reason: \"1мЭЄ кЄ∞мЧЕк∞А / AI мВђмЧЕ м†ДлЮµ мљШнЕРмЄ†\" },\n  { name: \"Mermaid\", domain: \"hello@mermaid.ai\", count: 1, cat: \"news\", catLabel: \"newsletter\", verdict: \"keep\", reason: \"Diagramming tool updates вАФ used in work\" },\n  { name: \"Medium Newsletter\", domain: \"newsletters@medium.com\", count: 1, cat: \"news\", catLabel: \"newsletter\", verdict: \"cut\", reason: \"Generic Medium digest вАФ low signal\" },\n  { name: \"Sider AI\", domain: \"no-reply@news.sider.ai\", count: 1, cat: \"promo\", catLabel: \"promo\", verdict: \"cut\", reason: \"Browser extension promo email\" },\n  { name: \"monday.com\", domain: \"team@learn.mail.monday.com\", count: 1, cat: \"promo\", catLabel: \"promo\", verdict: \"cut\", reason: \"Trial extension push вАФ unsubscribe\" },\n  { name: \"Make\", domain: \"info@make.com\", count: 1, cat: \"news\", catLabel: \"newsletter\", verdict: \"review\", reason: \"Automation platform вАФ keep if using Make\" },\n  { name: \"daily.dev\", domain: \"informer@daily.dev\", count: 1, cat: \"news\", catLabel: \"newsletter\", verdict: \"review\", reason: \"Dev news digest вАФ check if actively reading\" },\n  { name: \"Crew\", domain: \"no-reply@crew.you\", count: 2, cat: \"korea\", catLabel: \"нХЬкµ≠мЦі\", verdict: \"review\", reason: \"AI assistant onboarding emails\" },\n  { name: \"HEARTCOUNT\", domain: \"noreply@community.heartcount.io\", count: 1, cat: \"korea\", catLabel: \"нХЬкµ≠мЦі\", verdict: \"keep\", reason: \"лН∞мЭінД∞ лґДмДЭ мї§лЃ§лЛИнЛ∞ вАФ HR analytics кіАл†®\" },\n];\n\nconst maxCount = Math.max(...senders.map(s => s.count));\n\nconst catColors = {\n  news: \"#378ADD\",\n  promo: \"#D85A30\",\n  sys: \"#888780\",\n  korea: \"#639922\"\n};\nconst catBadgeClass = {\n  news: \"cat-news\",\n  promo: \"cat-promo\",\n  sys: \"cat-sys\",\n  korea: \"cat-korea\"\n};\nconst verdictClass = { cut: \"v-cut\", keep: \"v-keep\", review: \"v-review\" };\nconst verdictLabel = { cut: \"unsubscribe\", keep: \"keep\", review: \"review\" };\n\nfunction renderList(filter) {\n  const list = document.getElementById(\"sender-list\");\n  const data = filter === \"all\" ? senders : senders.filter(s => s.verdict === filter);\n  list.innerHTML = data.map(s => `\n    <div class=\"sender-row\">\n      <span class=\"sender-name\" title=\"${s.domain}\">${s.name}</span>\n      <span class=\"cat-badge ${catBadgeClass[s.cat]}\">${s.catLabel}</span>\n      <div class=\"bar-wrap\"><div class=\"bar\" style=\"width:${Math.round((s.count/maxCount)*100)}%; background:${catColors[s.cat]};\"></div></div>\n      <span class=\"sender-count\">${s.count}</span>\n      <span class=\"verdict ${verdictClass[s.verdict]}\">${verdictLabel[s.verdict]}</span>\n      <button class=\"action-btn\" onclick=\"sendPrompt('Tell me more about ${s.name} вАФ should I unsubscribe?')\">ask вЖЧ</button>\n    </div>\n  `).join(\"\");\n}\n\nfunction showTab(filter, el) {\n  document.querySelectorAll(\".tab\").forEach(t => t.classList.remove(\"active\"));\n  el.classList.add(\"active\");\n  renderList(filter);\n}\n\nrenderList(\"all\");\n\nconst catCounts = { news: 0, promo: 0, sys: 0, korea: 0 };\nsenders.forEach(s => { catCounts[s.cat] += s.count; });\n\nnew Chart(document.getElementById(\"catChart\"), {\n  type: \"bar\",\n  data: {\n    labels: [\"Newsletters\", \"Promotions\", \"System\", \"Korean\"],\n    datasets: [{\n      data: [catCounts.news, catCounts.promo, catCounts.sys, catCounts.korea],\n      backgroundColor: [\"#378ADD\", \"#D85A30\", \"#888780\", \"#639922\"],\n      borderRadius: 5,\n      borderSkipped: false\n    }]\n  },\n  options: {\n    responsive: true,\n    maintainAspectRatio: false,\n    plugins: { legend: { display: false } },\n    scales: {\n      x: { grid: { display: false }, ticks: { font: { size: 12 } } },\n      y: { grid: { color: \"rgba(128,128,128,0.1)\" }, ticks: { font: { size: 12 }, stepSize: 5 } }\n    }\n  }\n});\n</script>\n"
